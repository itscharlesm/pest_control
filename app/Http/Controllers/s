public function products_add(Request $request)
{
    // Validate the request
    $request->validate([
        'prd_name' => 'required|string|max:255',
        'cat_id' => 'required|exists:product_categories,cat_id',
        'prd_description' => 'nullable|string|max:500',
        'prd_unit_cost' => 'required|numeric|min:0',
        'prd_image' => 'nullable|file|mimes:webp,png,jpg,jpeg|max:8192', // 8MB max
    ]);

    // Ensure variables exist even when no file is uploaded
    $imageName = null;
    $destinationPath = public_path('images/products');

    // Handle the product image upload with compression
    if ($request->hasFile('prd_image')) {
        $attachment = $request->file('prd_image');
        // sanitize filename a bit
        $imageName = uniqid() . '_' . preg_replace('/\s+/', '_', $attachment->getClientOriginalName());

        if (!file_exists($destinationPath)) {
            mkdir($destinationPath, 0755, true);
        }

        $imagePath = $destinationPath . DIRECTORY_SEPARATOR . $imageName;
        $extension = strtolower($attachment->getClientOriginalExtension());

        try {
            if (in_array($extension, ['jpeg', 'jpg'])) {
                $source = @imagecreatefromjpeg($attachment->getPathname());
                if ($source !== false) {
                    imagejpeg($source, $imagePath, 75);
                } else {
                    // fallback: move as-is
                    $attachment->move($destinationPath, $imageName);
                }
            } elseif ($extension === 'png') {
                $source = @imagecreatefrompng($attachment->getPathname());
                if ($source !== false) {
                    if (function_exists('imagepalettetotruecolor') && !imageistruecolor($source)) {
                        imagepalettetotruecolor($source);
                    }
                    imagepng($source, $imagePath, 7); // compression level 0-9
                } else {
                    $attachment->move($destinationPath, $imageName);
                }
            } elseif ($extension === 'webp') {
                if (function_exists('imagecreatefromwebp') && function_exists('imagewebp')) {
                    $source = @imagecreatefromwebp($attachment->getPathname());
                    if ($source !== false) {
                        imagewebp($source, $imagePath, 75);
                    } else {
                        $attachment->move($destinationPath, $imageName);
                    }
                } else {
                    // If webp functions aren't available on the server, just move the file
                    $attachment->move($destinationPath, $imageName);
                }
            } else {
                // unsupported/other: move as-is
                $attachment->move($destinationPath, $imageName);
            }
        } finally {
            // free GD resource if created (works for both resource and GdImage)
            if (isset($source) && (is_resource($source) || $source instanceof \GdImage)) {
                imagedestroy($source);
            }
        }
    }

    // Insert data into the database
    DB::table('products')->insert([
        'prd_uuid' => generateuuid(),
        'cat_id' => $request->cat_id,
        'prd_name' => $request->prd_name,
        'prd_code' => generateProductCode(),
        'prd_description' => $request->prd_description,
        'prd_unit_cost' => $request->prd_unit_cost,
        'prd_image' => $imageName, // will be null when no image uploaded
        'prd_qty' => 0,
        'prd_date_created' => Carbon::now(),
        'prd_created_by' => session('usr_id'),
        'prd_active' => 1
    ]);

    logUserActivity('Manage Products', 'Added product ' . $request->prd_name . ' ' . $request->prd_name);
    session()->flash('successMessage', 'Product added successfully.');

    return redirect()->back();
}

